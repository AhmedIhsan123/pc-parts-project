<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>SurgeForge - Products</title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/images/SF_Logo.png" />

		<link rel="stylesheet" href="/css/base/styles.css" />
		<link rel="stylesheet" href="/css/products-page/products.css" />
		<link rel="stylesheet" href="/css/base/nav.css" />
		<link rel="stylesheet" href="/css/base/footer.css" />
		<link rel="stylesheet" href="/css/base/cursor.css" />

		<script src="/js/cursor.js" defer></script>
		<script src="/js/products.js" defer></script>

		<!-- Fonts -->
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Custom cursor -->
		<div class="custom-cursor"></div>

		<header><%- include('../partials/navigation') %></header>

		<main class="products-page">
			<!-- PAGE HEADER -->
			<section class="products-hero section" aria-labelledby="products-heading">
				<div class="container">
					<div class="products-hero__inner">
						<div>
							<p class="products-hero__breadcrumb">
								<a href="/">Home</a>
								<span aria-hidden="true"> / </span>
								<span>Products</span>
							</p>
							<h1 id="products-heading" class="products-hero__title">
								All <span class="accent">Components</span>
							</h1>
							<p class="products-hero__sub">
								<span id="products-count">140</span> parts across 7 categories —
								hand-picked for performance.
							</p>
						</div>
						<div class="products-hero__sort-row">
							<label for="sort-select" class="sr-only">Sort by</label>
							<div class="select-wrapper">
								<select id="sort-select" class="products-sort">
									<option value="featured">Sort: Featured</option>
									<option value="price-asc">Price: Low → High</option>
									<option value="price-desc">Price: High → Low</option>
									<option value="rating">Top Rated</option>
									<option value="newest">Newest</option>
									<option value="name-asc">Name: A → Z</option>
								</select>
								<span class="select-arrow" aria-hidden="true">▾</span>
							</div>
							<button
								class="btn-icon filter-toggle-mobile"
								aria-label="Toggle filters"
								aria-expanded="false"
							>
								<span>⚙</span> Filters
							</button>
						</div>
					</div>
				</div>
			</section>

			<!-- MAIN LAYOUT -->
			<div class="products-layout container">
				<!-- ===== SIDEBAR FILTERS ===== -->
				<aside
					class="filters-sidebar"
					id="filters-sidebar"
					aria-label="Product filters"
				>
					<div class="filters-sidebar__inner">
						<div class="filters-header">
							<span class="filters-title">Filters</span>
							<button class="filters-clear" type="button">Clear All</button>
						</div>

						<!-- CATEGORY -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-category"
							>
								Category
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-category">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="gpu" />
											<span class="check-box"></span>
											<span>GPUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="cpu" />
											<span class="check-box"></span>
											<span>CPUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input
												type="checkbox"
												name="category"
												value="motherboard"
											/>
											<span class="check-box"></span>
											<span>Motherboards</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="psu" />
											<span class="check-box"></span>
											<span>PSUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="ram" />
											<span class="check-box"></span>
											<span>RAM</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="storage" />
											<span class="check-box"></span>
											<span>Storage</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="case" />
											<span class="check-box"></span>
											<span>Cases</span>
											<span class="filter-count">20</span>
										</label>
									</li>
								</ul>
							</div>
						</div>

						<!-- PRICE RANGE -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-price"
							>
								Price Range
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-price">
								<div class="price-range">
									<div class="price-inputs">
										<div class="price-field">
											<label for="price-min" class="price-label">Min ($)</label>
											<input
												type="number"
												id="price-min"
												class="price-input"
												placeholder="0"
												min="0"
											/>
										</div>
										<span class="price-dash" aria-hidden="true">—</span>
										<div class="price-field">
											<label for="price-max" class="price-label">Max ($)</label>
											<input
												type="number"
												id="price-max"
												class="price-input"
												placeholder="3000"
												max="3000"
											/>
										</div>
									</div>
								</div>
							</div>
						</div>

						<!-- BRAND -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-brand"
							>
								Brand
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-brand">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="amd" /><span
												class="check-box"
											></span
											><span>AMD</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="intel" /><span
												class="check-box"
											></span
											><span>Intel</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="nvidia"
											/><span class="check-box"></span
											><span>NVIDIA</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="asus" /><span
												class="check-box"
											></span
											><span>ASUS</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="msi" /><span
												class="check-box"
											></span
											><span>MSI</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="gigabyte"
											/><span class="check-box"></span
											><span>Gigabyte</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="corsair"
											/><span class="check-box"></span
											><span>Corsair</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="gskill"
											/><span class="check-box"></span
											><span>G.Skill</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="samsung"
											/><span class="check-box"></span
											><span>Samsung</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="seagate"
											/><span class="check-box"></span
											><span>Seagate</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="evga" /><span
												class="check-box"
											></span
											><span>EVGA</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="seasonic"
											/><span class="check-box"></span
											><span>Seasonic</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="nzxt" /><span
												class="check-box"
											></span
											><span>NZXT</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="fractal"
											/><span class="check-box"></span
											><span>Fractal Design</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="lianli"
											/><span class="check-box"></span
											><span>Lian Li</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- RATING -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-rating"
							>
								Customer Rating
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-rating">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="4.5" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★★★ 4.5+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="4.0" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★★☆ 4.0+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="3.5" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★½☆ 3.5+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="3.0" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★☆☆ 3.0+</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- AVAILABILITY -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-availability"
							>
								Availability
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-availability">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="instock"
											/><span class="check-box"></span
											><span>In Stock</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="preorder"
											/><span class="check-box"></span
											><span>Pre-Order</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="backorder"
											/><span class="check-box"></span
											><span>Back Order</span></label
										>
									</li>
								</ul>
							</div>
						</div>
					</div>
					<!-- /.filters-sidebar__inner -->
				</aside>
				<!-- ===== END SIDEBAR ===== -->

				<!-- ===== PRODUCT GRID AREA ===== -->
				<section class="products-main" aria-label="Product listing">
					<!-- Active filters bar -->
					<div class="active-filters" id="active-filters" aria-live="polite">
						<!-- Active filter tags will be injected here by JS -->
					</div>

					<!-- Product grid -->
					<ul class="products-grid" role="list" id="products-grid">
						<!-- GPU -->
						<li class="product-card products-card" data-category="gpu">
							<div class="product-card__top">
								<span class="product-badge product-badge--hot">Bestseller</span>
								<span class="product-category">GPU</span>
							</div>
							<div class="products-card__image">
								<img src="/images/4090.jpg" alt="RTX 4090" loading="lazy" />
							</div>
							<h3 class="products-card__name">RTX 4090</h3>
							<p class="products-card__desc">
								Extreme 4K Gaming GPU — 24GB GDDR6X
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">24 GB VRAM</span>
								<span class="spec-tag">Ada Lovelace</span>
								<span class="spec-tag">Ada Lovelace</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$1,699</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<li class="product-card products-card" data-category="gpu">
							<div class="product-card__top">
								<span class="product-badge product-badge--rated">4.9 ★</span>
								<span class="product-category">GPU</span>
							</div>
							<div class="products-card__image">
								<img
									src="/images/4080S.png"
									alt="RTX 4080 Super"
									loading="lazy"
								/>
							</div>
							<h3 class="products-card__name">RTX 4080 Super</h3>
							<p class="products-card__desc">
								Elite 1440p / 4K GPU — 16GB GDDR6X
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">16 GB VRAM</span>
								<span class="spec-tag">Ada Lovelace</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$999</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<!-- CPU -->
						<li class="product-card products-card" data-category="cpu">
							<div class="product-card__top">
								<span class="product-badge product-badge--hot">Popular</span>
								<span class="product-category">CPU</span>
							</div>
							<div class="products-card__image">
								<img
									src="/images/7950X.jpg"
									alt="Ryzen 9 7950X"
									loading="lazy"
								/>
							</div>
							<h3 class="products-card__name">Ryzen 9 7950X</h3>
							<p class="products-card__desc">
								16-Core / 32-Thread Workstation CPU
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">AM5</span>
								<span class="spec-tag">16 Cores</span>
								<span class="spec-tag">170W TDP</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$599</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<li class="product-card products-card" data-category="cpu">
							<div class="product-card__top">
								<span class="product-badge product-badge--rated">4.8 ★</span>
								<span class="product-category">CPU</span>
							</div>
							<div class="products-card__image">
								<img
									src="/images/14900K.jpg"
									alt="Intel i9-14900K"
									loading="lazy"
								/>
							</div>
							<h3 class="products-card__name">Intel i9-14900K</h3>
							<p class="products-card__desc">
								Next-Gen Gaming & Workstation CPU
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">LGA1700</span>
								<span class="spec-tag">24 Cores</span>
								<span class="spec-tag">125W TDP</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$589</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<!-- RAM -->
						<li class="product-card products-card" data-category="ram">
							<div class="product-card__top">
								<span class="product-badge">In Stock</span>
								<span class="product-category">RAM</span>
							</div>
							<div class="products-card__image">
								<img
									src="/images/DDR5.jpg"
									alt="DDR5 32GB Kit"
									loading="lazy"
								/>
							</div>
							<h3 class="products-card__name">G.Skill Trident Z5 32GB</h3>
							<p class="products-card__desc">
								6000MHz High-Speed Dual Channel Memory
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">DDR5</span>
								<span class="spec-tag">32 GB Kit</span>
								<span class="spec-tag">6000 MHz</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$189</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<!-- Storage -->
						<li class="product-card products-card" data-category="storage">
							<div class="product-card__top">
								<span class="product-badge product-badge--rated">4.9 ★</span>
								<span class="product-category">Storage</span>
							</div>
							<div class="products-card__image">
								<img
									src="/images/SSD.jpg"
									alt="2TB NVMe Gen4 SSD"
									loading="lazy"
								/>
							</div>
							<h3 class="products-card__name">Samsung 990 Pro 2TB</h3>
							<p class="products-card__desc">
								7,400 MB/s Sequential Read Speed
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">NVMe</span>
								<span class="spec-tag">PCIe Gen 4</span>
								<span class="spec-tag">2 TB</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$159</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<!-- Placeholder cards to fill the grid -->
						<li
							class="product-card products-card products-card--placeholder"
							data-category="motherboard"
						>
							<div class="product-card__top">
								<span class="product-badge">New</span>
								<span class="product-category">Motherboard</span>
							</div>
							<div class="products-card__image products-card__image--empty">
								<span class="image-placeholder-icon" aria-hidden="true"
									>🖥</span
								>
							</div>
							<h3 class="products-card__name">ASUS ROG Crosshair X670E</h3>
							<p class="products-card__desc">
								Extreme AM5 Gaming Motherboard — ATX
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">AM5</span>
								<span class="spec-tag">X670E</span>
								<span class="spec-tag">DDR5</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$649</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<li
							class="product-card products-card products-card--placeholder"
							data-category="psu"
						>
							<div class="product-card__top">
								<span class="product-badge">In Stock</span>
								<span class="product-category">PSU</span>
							</div>
							<div class="products-card__image products-card__image--empty">
								<span class="image-placeholder-icon" aria-hidden="true"
									>⚡</span
								>
							</div>
							<h3 class="products-card__name">Seasonic Prime TX-1000</h3>
							<p class="products-card__desc">
								1000W Fully Modular — 80 Plus Titanium
							</p>
							<div class="products-card__specs">
								<span class="spec-tag">1000W</span>
								<span class="spec-tag">Titanium</span>
								<span class="spec-tag">Fully Modular</span>
							</div>
							<div class="product-card__bottom">
								<span class="price">$299</span>
								<a href="#" class="product-link">View →</a>
							</div>
						</li>

						<li
							class="product-card products-card products-card--placeholder"
							data-category="case"
						>
							<div class="product-card__top">
