<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>SurgeForge - Products</title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/images/SF_Logo.png" />

		<link rel="stylesheet" href="/css/base/styles.css" />
		<link rel="stylesheet" href="/css/products-page/products.css" />
		<link rel="stylesheet" href="/css/base/nav.css" />
		<link rel="stylesheet" href="/css/base/footer.css" />
		<link rel="stylesheet" href="/css/base/cursor.css" />

		<script src="/js/cursor.js" defer></script>
		<script src="/js/default.js" defer></script>

		<!-- Fonts -->
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Custom cursor -->
		<div class="custom-cursor"></div>

		<header><%- include('../partials/navigation') %></header>

		<main class="products-page">
			<!-- PAGE HEADER -->
			<section class="products-hero section" aria-labelledby="products-heading">
				<div class="container">
					<div class="products-hero__inner">
						<div>
							<p class="products-hero__breadcrumb">
								<a href="/">Home</a>
								<span aria-hidden="true"> / </span>
								<span>Products</span>
							</p>
							<h1 id="products-heading" class="products-hero__title">
								All <span class="accent">Components</span>
							</h1>
							<p class="products-hero__sub">
								<span id="products-count">140</span> parts across 7 categories —
								hand-picked for performance.
							</p>
						</div>
						<div class="products-hero__sort-row">
							<label for="sort-select" class="sr-only">Sort by</label>
							<div class="select-wrapper">
								<select id="sort-select" class="products-sort">
									<option value="featured">Sort: Featured</option>
									<option value="price-asc">Price: Low → High</option>
									<option value="price-desc">Price: High → Low</option>
									<option value="rating">Top Rated</option>
									<option value="newest">Newest</option>
									<option value="name-asc">Name: A → Z</option>
								</select>
								<span class="select-arrow" aria-hidden="true">▾</span>
							</div>
							<button
								class="btn-icon filter-toggle-mobile"
								aria-label="Toggle filters"
								aria-expanded="false"
							>
								<span>⚙</span> Filters
							</button>
						</div>
					</div>
				</div>
			</section>

			<!-- MAIN LAYOUT -->
			<div class="products-layout container">
				<!-- ===== SIDEBAR FILTERS ===== -->
				<aside
					class="filters-sidebar"
					id="filters-sidebar"
					aria-label="Product filters"
				>
					<div class="filters-sidebar__inner">
						<div class="filters-header">
							<span class="filters-title">Filters</span>
							<button class="filters-clear" type="button">Clear All</button>
						</div>

						<!-- CATEGORY -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-category"
							>
								Category
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-category">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="gpu" />
											<span class="check-box"></span>
											<span>GPUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="cpu" />
											<span class="check-box"></span>
											<span>CPUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input
												type="checkbox"
												name="category"
												value="motherboard"
											/>
											<span class="check-box"></span>
											<span>Motherboards</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="psu" />
											<span class="check-box"></span>
											<span>PSUs</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="ram" />
											<span class="check-box"></span>
											<span>RAM</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="storage" />
											<span class="check-box"></span>
											<span>Storage</span>
											<span class="filter-count">20</span>
										</label>
									</li>
									<li>
										<label class="filter-check">
											<input type="checkbox" name="category" value="case" />
											<span class="check-box"></span>
											<span>Cases</span>
											<span class="filter-count">20</span>
										</label>
									</li>
								</ul>
							</div>
						</div>

						<!-- PRICE RANGE -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-price"
							>
								Price Range
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-price">
								<div class="price-range">
									<div class="price-inputs">
										<div class="price-field">
											<label for="price-min" class="price-label">Min ($)</label>
											<input
												type="number"
												id="price-min"
												class="price-input"
												placeholder="0"
												min="0"
											/>
										</div>
										<span class="price-dash" aria-hidden="true">—</span>
										<div class="price-field">
											<label for="price-max" class="price-label">Max ($)</label>
											<input
												type="number"
												id="price-max"
												class="price-input"
												placeholder="3000"
												max="3000"
											/>
										</div>
									</div>
									<div class="price-presets">
										<button class="price-preset" type="button">
											Under $100
										</button>
										<button class="price-preset" type="button">
											$100–$300
										</button>
										<button class="price-preset" type="button">
											$300–$600
										</button>
										<button class="price-preset" type="button">$600+</button>
									</div>
								</div>
							</div>
						</div>

						<!-- BRAND -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-brand"
							>
								Brand
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-brand">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="amd" /><span
												class="check-box"
											></span
											><span>AMD</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="intel" /><span
												class="check-box"
											></span
											><span>Intel</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="nvidia"
											/><span class="check-box"></span
											><span>NVIDIA</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="asus" /><span
												class="check-box"
											></span
											><span>ASUS</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="msi" /><span
												class="check-box"
											></span
											><span>MSI</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="gigabyte"
											/><span class="check-box"></span
											><span>Gigabyte</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="corsair"
											/><span class="check-box"></span
											><span>Corsair</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="gskill"
											/><span class="check-box"></span
											><span>G.Skill</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="samsung"
											/><span class="check-box"></span
											><span>Samsung</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="seagate"
											/><span class="check-box"></span
											><span>Seagate</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="evga" /><span
												class="check-box"
											></span
											><span>EVGA</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="seasonic"
											/><span class="check-box"></span
											><span>Seasonic</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="brand" value="nzxt" /><span
												class="check-box"
											></span
											><span>NZXT</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="fractal"
											/><span class="check-box"></span
											><span>Fractal Design</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="brand"
												value="lianli"
											/><span class="check-box"></span
											><span>Lian Li</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- RATING -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-rating"
							>
								Customer Rating
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-rating">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="4.5" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★★★ 4.5+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="4.0" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★★☆ 4.0+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="3.5" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★½☆ 3.5+</span></label
										>
									</li>
									<li>
										<label class="filter-check filter-check--stars"
											><input type="radio" name="rating" value="3.0" /><span
												class="check-box check-box--radio"
											></span
											><span class="stars-label">★★★☆☆ 3.0+</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- AVAILABILITY -->
						<div class="filter-group">
							<button
								class="filter-group__toggle"
								aria-expanded="true"
								aria-controls="filter-availability"
							>
								Availability
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div class="filter-group__body" id="filter-availability">
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="instock"
											/><span class="check-box"></span
											><span>In Stock</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="preorder"
											/><span class="check-box"></span
											><span>Pre-Order</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="availability"
												value="backorder"
											/><span class="check-box"></span
											><span>Back Order</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- ===== GPU-SPECIFIC FILTERS ===== -->
						<div class="filter-section-label" data-category="gpu">
							<span>GPU Filters</span>
						</div>

						<div
							class="filter-group filter-group--category"
							data-category="gpu"
						>
							<button
								class="filter-group__toggle"
								aria-expanded="false"
								aria-controls="filter-gpu-vram"
							>
								VRAM
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div
								class="filter-group__body filter-group__body--collapsed"
								id="filter-gpu-vram"
							>
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input type="checkbox" name="vram" value="8" /><span
												class="check-box"
											></span
											><span>8 GB</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="vram" value="12" /><span
												class="check-box"
											></span
											><span>12 GB</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="vram" value="16" /><span
												class="check-box"
											></span
											><span>16 GB</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="vram" value="20" /><span
												class="check-box"
											></span
											><span>20 GB</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="vram" value="24" /><span
												class="check-box"
											></span
											><span>24 GB</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<div
							class="filter-group filter-group--category"
							data-category="gpu"
						>
							<button
								class="filter-group__toggle"
								aria-expanded="false"
								aria-controls="filter-gpu-arch"
							>
								Architecture
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div
								class="filter-group__body filter-group__body--collapsed"
								id="filter-gpu-arch"
							>
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-arch"
												value="ada"
											/><span class="check-box"></span
											><span>NVIDIA Ada Lovelace</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-arch"
												value="blackwell"
											/><span class="check-box"></span
											><span>NVIDIA Blackwell</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-arch"
												value="rdna3"
											/><span class="check-box"></span
											><span>AMD RDNA 3</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-arch"
												value="rdna4"
											/><span class="check-box"></span
											><span>AMD RDNA 4</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<div
							class="filter-group filter-group--category"
							data-category="gpu"
						>
							<button
								class="filter-group__toggle"
								aria-expanded="false"
								aria-controls="filter-gpu-segment"
							>
								Performance Tier
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div
								class="filter-group__body filter-group__body--collapsed"
								id="filter-gpu-segment"
							>
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-tier"
												value="entry"
											/><span class="check-box"></span
											><span>Entry (1080p)</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-tier"
												value="mid"
											/><span class="check-box"></span
											><span>Mid (1440p)</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-tier"
												value="high"
											/><span class="check-box"></span
											><span>High (4K)</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input
												type="checkbox"
												name="gpu-tier"
												value="flagship"
											/><span class="check-box"></span
											><span>Flagship</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<!-- ===== CPU-SPECIFIC FILTERS ===== -->
						<div class="filter-section-label" data-category="cpu">
							<span>CPU Filters</span>
						</div>

						<div
							class="filter-group filter-group--category"
							data-category="cpu"
						>
							<button
								class="filter-group__toggle"
								aria-expanded="false"
								aria-controls="filter-cpu-socket"
							>
								Socket
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div
								class="filter-group__body filter-group__body--collapsed"
								id="filter-cpu-socket"
							>
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input type="checkbox" name="socket" value="am5" /><span
												class="check-box"
											></span
											><span>AMD AM5</span></label
										>
									</li>
									<li>
										<label class="filter-check"
