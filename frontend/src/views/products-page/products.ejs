<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>SurgeForge - Products</title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/images/SF_Logo.png" />

		<link rel="stylesheet" href="/css/base/styles.css" />
		<link rel="stylesheet" href="/css/base/nav.css" />
		<link rel="stylesheet" href="/css/base/footer.css" />
		<link rel="stylesheet" href="/css/base/cursor.css" />
		<link rel="stylesheet" href="/css/products-page/products.css" />

		<script src="/js/products.js" defer></script>
		<script src="/js/cursor.js" defer></script>

		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="custom-cursor"></div>

		<header><%- include('../partials/navigation') %></header>

		<main class="products-main landing">
			<div class="landing-glow landing-glow--1" aria-hidden="true"></div>
			<div class="landing-glow landing-glow--2" aria-hidden="true"></div>
			<div class="landing-glow landing-glow--3" aria-hidden="true"></div>

			<div class="products-layout container">
				<!-- FILTER SIDEBAR -->
				<aside class="filter-sidebar" aria-label="Product filters">
					<div class="filter-sidebar__header">
						<span class="filter-sidebar__title">Filters</span>
						<button class="filter-clear" id="clearFilters">Clear all</button>
					</div>

					<!-- Category -->
					<div class="filter-group">
						<button
							class="filter-group__toggle"
							aria-expanded="true"
							aria-controls="filter-category"
						>
							<span>Category</span>
							<span class="filter-group__arrow">▾</span>
						</button>
						<ul class="filter-options" id="filter-category" role="list">
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="gpu" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">GPU</span>
									<span class="filter-checkbox__count">12</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="cpu" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">CPU</span>
									<span class="filter-checkbox__count">9</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="ram" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">RAM</span>
									<span class="filter-checkbox__count">7</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="storage" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Storage</span>
									<span class="filter-checkbox__count">8</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="cooling" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Cooling</span>
									<span class="filter-checkbox__count">5</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="category" value="psu" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">PSU</span>
									<span class="filter-checkbox__count">4</span>
								</label>
							</li>
						</ul>
					</div>

					<!-- Brand -->
					<div class="filter-group">
						<button
							class="filter-group__toggle"
							aria-expanded="true"
							aria-controls="filter-brand"
						>
							<span>Brand</span>
							<span class="filter-group__arrow">▾</span>
						</button>
						<ul class="filter-options" id="filter-brand" role="list">
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="nvidia" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">NVIDIA</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="amd" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">AMD</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="intel" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Intel</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="corsair" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Corsair</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="samsung" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Samsung</span>
								</label>
							</li>
						</ul>
					</div>

					<!-- Price Range -->
					<div class="filter-group">
						<button
							class="filter-group__toggle"
							aria-expanded="true"
							aria-controls="filter-price"
						>
							<span>Price Range</span>
							<span class="filter-group__arrow">▾</span>
						</button>
						<div class="filter-options" id="filter-price">
							<div class="price-range">
								<div class="price-range__labels">
									<span id="price-min-label">$0</span>
									<span id="price-max-label">$2,000</span>
								</div>
								<div class="price-range__slider-wrap">
									<input
										type="range"
										class="price-slider"
										id="price-min"
										min="0"
										max="2000"
										value="0"
										step="50"
									/>
									<input
										type="range"
										class="price-slider"
										id="price-max"
										min="0"
										max="2000"
										value="2000"
										step="50"
									/>
								</div>
							</div>
						</div>
					</div>

					<!-- Rating -->
					<div class="filter-group">
						<button
							class="filter-group__toggle"
							aria-expanded="true"
							aria-controls="filter-rating"
						>
							<span>Min. Rating</span>
							<span class="filter-group__arrow">▾</span>
						</button>
						<ul class="filter-options" id="filter-rating" role="list">
							<li>
								<label class="filter-checkbox">
									<input type="radio" name="rating" value="4.5" />
									<span
										class="filter-checkbox__box filter-checkbox__box--radio"
									></span>
									<span class="filter-checkbox__label">★★★★★ 4.5+</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="radio" name="rating" value="4.0" />
									<span
										class="filter-checkbox__box filter-checkbox__box--radio"
									></span>
									<span class="filter-checkbox__label">★★★★☆ 4.0+</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="radio" name="rating" value="3.0" />
									<span
										class="filter-checkbox__box filter-checkbox__box--radio"
									></span>
									<span class="filter-checkbox__label">★★★☆☆ 3.0+</span>
								</label>
							</li>
						</ul>
					</div>

					<!-- Availability -->
					<div class="filter-group">
						<button
							class="filter-group__toggle"
							aria-expanded="true"
							aria-controls="filter-avail"
						>
							<span>Availability</span>
							<span class="filter-group__arrow">▾</span>
						</button>
						<ul class="filter-options" id="filter-avail" role="list">
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="availability" value="instock" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">In Stock</span>
								</label>
							</li>
							<li>
								<label class="filter-checkbox">
									<input type="checkbox" name="availability" value="preorder" />
									<span class="filter-checkbox__box"></span>
									<span class="filter-checkbox__label">Pre-Order</span>
								</label>
							</li>
						</ul>
					</div>
				</aside>

				<!-- PRODUCTS AREA -->
				<section class="products-content" aria-labelledby="products-heading">
					<!-- Top bar -->
					<div class="products-topbar">
						<div class="products-topbar__left">
							<h1 class="products-heading" id="products-heading">
								All Products
							</h1>
							<span class="products-count" id="products-count">45 results</span>
						</div>
						<div class="products-topbar__right">
							<label class="sr-only" for="sort-select">Sort by</label>
							<select class="sort-select" id="sort-select">
								<option value="featured">Featured</option>
								<option value="price-asc">Price: Low to High</option>
								<option value="price-desc">Price: High to Low</option>
								<option value="rating">Top Rated</option>
								<option value="newest">Newest</option>
							</select>
							<div class="view-toggle" role="group" aria-label="View layout">
								<button
									class="view-btn view-btn--active"
									data-view="grid"
									aria-label="Grid view"
								>
									<svg
										width="16"
										height="16"
										viewBox="0 0 16 16"
										fill="currentColor"
									>
										<rect x="0" y="0" width="7" height="7" rx="1" />
										<rect x="9" y="0" width="7" height="7" rx="1" />
										<rect x="0" y="9" width="7" height="7" rx="1" />
										<rect x="9" y="9" width="7" height="7" rx="1" />
									</svg>
								</button>
								<button
									class="view-btn"
									data-view="list"
									aria-label="List view"
								>
									<svg
										width="16"
										height="16"
										viewBox="0 0 16 16"
										fill="currentColor"
									>
										<rect x="0" y="1" width="16" height="2" rx="1" />
										<rect x="0" y="7" width="16" height="2" rx="1" />
										<rect x="0" y="13" width="16" height="2" rx="1" />
									</svg>
								</button>
							</div>
						</div>
					</div>

					<!-- Active Filters -->
					<div
						class="active-filters"
						id="activeFilters"
						aria-live="polite"
					></div>

					<!-- Product Grid -->
					<ul class="products-grid" id="productsGrid" role="list">
						<li
							class="pcard"
							data-category="gpu"
							data-brand="nvidia"
							data-price="1699"
							data-rating="4.9"
						>
							<a href="/products/rtx-4090" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/4090.jpg"
										alt="RTX 4090"
										class="pcard__img"
									/>
									<span class="pcard__badge pcard__badge--hot">Bestseller</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">GPU</span>
										<span class="pcard__rating">★ 4.9</span>
									</div>
									<h2 class="pcard__name">RTX 4090</h2>
									<p class="pcard__desc">Extreme 4K Gaming — 24GB GDDR6X</p>
									<div class="pcard__footer">
										<span class="pcard__price">$1,699</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>

						<li
							class="pcard"
							data-category="gpu"
							data-brand="nvidia"
							data-price="999"
							data-rating="4.9"
						>
							<a href="/products/rtx-4080-super" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/4080S.png"
										alt="RTX 4080 Super"
										class="pcard__img"
									/>
									<span class="pcard__badge pcard__badge--rated">4.9 ★</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">GPU</span>
										<span class="pcard__rating">★ 4.9</span>
									</div>
									<h2 class="pcard__name">RTX 4080 Super</h2>
									<p class="pcard__desc">
										Elite 1440p / 4K Gaming — 16GB GDDR6X
									</p>
									<div class="pcard__footer">
										<span class="pcard__price">$999</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>

						<li
							class="pcard"
							data-category="cpu"
							data-brand="amd"
							data-price="599"
							data-rating="4.8"
						>
							<a href="/products/ryzen-9-7950x" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/7950x.jpg"
										alt="Ryzen 9 7950X"
										class="pcard__img"
									/>
									<span class="pcard__badge pcard__badge--hot">Popular</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">CPU</span>
										<span class="pcard__rating">★ 4.8</span>
									</div>
									<h2 class="pcard__name">Ryzen 9 7950X</h2>
									<p class="pcard__desc">16-Core / 32-Thread Performance CPU</p>
									<div class="pcard__footer">
										<span class="pcard__price">$599</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>

						<li
							class="pcard"
							data-category="cpu"
							data-brand="intel"
							data-price="589"
							data-rating="4.8"
						>
							<a href="/products/i9-14900k" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/14900K.jpg"
										alt="Intel i9-14900K"
										class="pcard__img"
									/>
									<span class="pcard__badge pcard__badge--rated">4.8 ★</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">CPU</span>
										<span class="pcard__rating">★ 4.8</span>
									</div>
									<h2 class="pcard__name">Intel i9-14900K</h2>
									<p class="pcard__desc">Next-Gen Gaming & Workstation CPU</p>
									<div class="pcard__footer">
										<span class="pcard__price">$589</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>

						<li
							class="pcard"
							data-category="ram"
							data-brand="corsair"
							data-price="189"
							data-rating="4.7"
						>
							<a href="/products/ddr5-32gb" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/DDR5.jpg"
										alt="DDR5 32GB Kit"
										class="pcard__img"
									/>
									<span class="pcard__badge">In Stock</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">RAM</span>
										<span class="pcard__rating">★ 4.7</span>
									</div>
									<h2 class="pcard__name">DDR5 32GB Kit</h2>
									<p class="pcard__desc">6000MHz High-Speed Dual Channel</p>
									<div class="pcard__footer">
										<span class="pcard__price">$189</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>

						<li
							class="pcard"
							data-category="storage"
							data-brand="samsung"
							data-price="159"
							data-rating="4.9"
						>
							<a href="/products/2tb-nvme-gen4" class="pcard__link">
								<div class="pcard__img-wrap">
									<img
										src="/images/SSD.jpg"
										alt="2TB NVMe Gen4 SSD"
										class="pcard__img"
									/>
									<span class="pcard__badge pcard__badge--rated">4.9 ★</span>
								</div>
								<div class="pcard__body">
									<div class="pcard__meta">
										<span class="pcard__category">Storage</span>
										<span class="pcard__rating">★ 4.9</span>
									</div>
									<h2 class="pcard__name">2TB NVMe Gen4 SSD</h2>
									<p class="pcard__desc">7,400 MB/s Sequential Read Speed</p>
									<div class="pcard__footer">
										<span class="pcard__price">$159</span>
										<span class="pcard__cta">View Details →</span>
									</div>
								</div>
							</a>
						</li>
					</ul>

					<!-- No results state -->
					<div class="no-results" id="noResults" hidden>
						<span class="no-results__icon">🔍</span>
						<p class="no-results__text">No products match your filters.</p>
						<button class="btn btn-secondary" id="clearFiltersAlt">
							Clear Filters
						</button>
					</div>
				</section>
			</div>

			<!-- Mobile filter toggle -->
			<button
				class="filter-mobile-toggle"
				id="filterMobileToggle"
				aria-expanded="false"
				aria-controls="filterSidebar"
			>
				<span>⚙ Filters</span>
			</button>
		</main>

		<%- include('../partials/footer') %>
	</body>
</html>
