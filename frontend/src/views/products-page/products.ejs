										<label class="filter-check"
											><input
												type="checkbox"
												name="socket"
												value="lga1851"
											/><span class="check-box"></span
											><span>Intel LGA1851</span></label
										>
									</li>
								</ul>
							</div>
						</div>

						<div
							class="filter-group filter-group--category"
							data-category="cpu"
						>
							<button
								class="filter-group__toggle"
								aria-expanded="false"
								aria-controls="filter-cpu-cores"
							>
								Core Count
								<span class="filter-group__arrow" aria-hidden="true">▾</span>
							</button>
							<div
								class="filter-group__body filter-group__body--collapsed"
								id="filter-cpu-cores"
							>
								<ul class="filter-checklist" role="list">
									<li>
										<label class="filter-check"
											><input type="checkbox" name="cores" value="6" /><span
												class="check-box"
											></span
											><span>6 Cores</span></label
										>
									</li>
									<li>
										<label class="filter-check"
											><input type="checkbox" name="cores" value="8" /><span
												class="check-box"
											></span
											><span>8 Cores</span></label
										>
									</li>
