<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>SurgeForge - <%= product.name %></title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/images/SF_Logo.png" />

		<link rel="stylesheet" href="/css/base/styles.css" />
		<link rel="stylesheet" href="/css/base/nav.css" />
		<link rel="stylesheet" href="/css/base/footer.css" />
		<link rel="stylesheet" href="/css/base/cursor.css" />
		<link rel="stylesheet" href="/css/products-page/product.css" />

		<script src="/js/product.js" defer></script>
		<script src="/js/cursor.js" defer></script>

		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="custom-cursor"></div>

		<header><%- include('../partials/navigation') %></header>

		<main class="product-main landing">
			<div class="landing-glow landing-glow--1" aria-hidden="true"></div>
			<div class="landing-glow landing-glow--2" aria-hidden="true"></div>

			<div class="product-layout container">

				<!-- Breadcrumb -->
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href="/" class="breadcrumb__link">Home</a>
					<span class="breadcrumb__sep" aria-hidden="true">›</span>
					<a href="/products" class="breadcrumb__link">Products</a>
					<span class="breadcrumb__sep" aria-hidden="true">›</span>
					<span class="breadcrumb__current" aria-current="page"><%= product.category %></span>
					<span class="breadcrumb__sep" aria-hidden="true">›</span>
					<span class="breadcrumb__current" aria-current="page"><%= product.name %></span>
				</nav>

				<!-- Product Detail -->
				<div class="product-detail">

					<!-- LEFT: Images -->
					<div class="product-gallery">
						<div class="product-gallery__main">
							<img
								src="<%= product.image %>"
								alt="<%= product.name %>"
								class="product-gallery__img"
								id="mainImage"
							/>
							<div class="product-gallery__glow" aria-hidden="true"></div>
						</div>
						<div class="product-gallery__thumbs" role="list" aria-label="Product images">
							<button class="product-gallery__thumb product-gallery__thumb--active" data-src="<%= product.image %>" aria-label="Image 1">
								<img src="<%= product.image %>" alt="" />
							</button>
							<% if (product.images) { product.images.forEach((img, i) => { %>
							<button class="product-gallery__thumb" data-src="<%= img %>" aria-label="Image <%= i + 2 %>">
								<img src="<%= img %>" alt="" />
							</button>
							<% }) } %>
						</div>
					</div>

					<!-- RIGHT: Info -->
					<div class="product-info">
						<div class="product-info__top">
							<span class="product-info__category"><%= product.category %></span>
							<% if (product.badge) { %>
							<span class="product-badge product-badge--hot"><%= product.badge %></span>
							<% } %>
						</div>

						<h1 class="product-info__name"><%= product.name %></h1>

						<div class="product-info__rating" aria-label="Rating: <%= product.rating %> out of 5">
							<span class="product-info__stars" aria-hidden="true">
								<%
									const fullStars = Math.floor(product.rating);
									const hasHalf = product.rating % 1 >= 0.5;
									for (let i = 0; i < 5; i++) {
										if (i < fullStars) { %><span class="star star--full">★</span><% }
										else if (i === fullStars && hasHalf) { %><span class="star star--half">★</span><% }
										else { %><span class="star star--empty">★</span><% }
									}
								%>
							</span>
							<span class="product-info__rating-value"><%= product.rating %></span>
							<span class="product-info__review-count">(<%= product.reviewCount %> reviews)</span>
						</div>

						<p class="product-info__desc"><%= product.description %></p>

						<!-- Specs Preview -->
						<ul class="product-specs-preview" role="list">
							<% product.specHighlights.forEach(spec => { %>
							<li class="product-specs-preview__item">
								<span class="product-specs-preview__icon" aria-hidden="true">▸</span>
								<span><%= spec %></span>
							</li>
							<% }) %>
						</ul>

						<!-- Price + Actions -->
						<div class="product-purchase">
							<div class="product-purchase__price-row">
								<span class="product-purchase__price">$<%= product.price.toLocaleString() %></span>
								<% if (product.originalPrice) { %>
								<span class="product-purchase__original">$<%= product.originalPrice.toLocaleString() %></span>
								<span class="product-purchase__save">Save $<%= (product.originalPrice - product.price).toLocaleString() %></span>
								<% } %>
							</div>

							<div class="product-purchase__stock">
								<span class="product-purchase__stock-dot" aria-hidden="true"></span>
								<span><%= product.inStock ? 'In Stock — Ships today if ordered before 3PM' : 'Out of Stock' %></span>
							</div>

							<div class="product-purchase__actions">
								<div class="qty-control" aria-label="Quantity">
									<button class="qty-btn" id="qtyMinus" aria-label="Decrease quantity">−</button>
									<span class="qty-value" id="qtyValue">1</span>
									<button class="qty-btn" id="qtyPlus" aria-label="Increase quantity">+</button>
								</div>
								<button class="btn btn-primary product-purchase__add" id="addToCart">
									Add to Cart
								</button>
							</div>

							<a href="/checkout" class="btn btn-secondary product-purchase__checkout">
								Buy Now →
							</a>
						</div>

						<!-- Trust badges -->
						<ul class="product-trust" role="list">
							<li class="product-trust__item">
								<span aria-hidden="true">🔒</span> Verified Authentic
							</li>
							<li class="product-trust__item">
								<span aria-hidden="true">↩️</span> 30-Day Returns
							</li>
							<li class="product-trust__item">
								<span aria-hidden="true">⚡</span> Same-Day Dispatch
							</li>
						</ul>
					</div>
				</div>

				<!-- Tabs: Full Specs / Reviews / Compatibility -->
				<div class="product-tabs">
					<div class="product-tabs__nav" role="tablist">
						<button class="product-tab-btn product-tab-btn--active" role="tab" aria-selected="true" aria-controls="tab-specs" id="btn-specs">
							Full Specs
						</button>
						<button class="product-tab-btn" role="tab" aria-selected="false" aria-controls="tab-reviews" id="btn-reviews">
							Reviews (<%= product.reviewCount %>)
						</button>
						<button class="product-tab-btn" role="tab" aria-selected="false" aria-controls="tab-compat" id="btn-compat">
							Compatibility
						</button>
					</div>

					<!-- Specs Tab -->
					<div class="product-tab-panel" id="tab-specs" role="tabpanel" aria-labelledby="btn-specs">
						<dl class="specs-table">
							<% product.specs.forEach(spec => { %>
							<div class="specs-table__row">
								<dt class="specs-table__key"><%= spec.key %></dt>
								<dd class="specs-table__val"><%= spec.value %></dd>
							</div>
							<% }) %>
						</dl>
					</div>

					<!-- Reviews Tab -->
					<div class="product-tab-panel product-tab-panel--hidden" id="tab-reviews" role="tabpanel" aria-labelledby="btn-reviews">
						<div class="reviews-summary">
							<div class="reviews-summary__score">
								<span class="reviews-summary__big"><%= product.rating %></span>
								<span class="reviews-summary__stars" aria-hidden="true">★★★★★</span>
								<span class="reviews-summary__total"><%= product.reviewCount %> reviews</span>
							</div>
						</div>
						<ul class="reviews-list" role="list">
							<% product.reviews.forEach(review => { %>
							<li class="review-card">
								<div class="review-card__header">
									<span class="review-card__author"><%= review.author %></span>
									<span class="review-card__stars" aria-label="<%= review.rating %> stars">
										<%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %>
									</span>
									<span class="review-card__date"><%= review.date %></span>
								</div>
								<p class="review-card__text"><%= review.text %></p>
							</li>
							<% }) %>
						</ul>
					</div>

					<!-- Compatibility Tab -->
					<div class="product-tab-panel product-tab-panel--hidden" id="tab-compat" role="tabpanel" aria-labelledby="btn-compat">
						<div class="compat-info">
							<% product.compatibility.forEach(group => { %>
							<div class="compat-group">
								<h3 class="compat-group__title"><%= group.title %></h3>
								<ul class="compat-group__list" role="list">
									<% group.items.forEach(item => { %>
									<li class="compat-group__item">
										<span class="compat-group__status compat-group__status--<%= item.status %>" aria-hidden="true">
											<%= item.status === 'yes' ? '✓' : item.status === 'partial' ? '◑' : '✗' %>
										</span>
										<%= item.name %>
									</li>
									<% }) %>
								</ul>
							</div>
							<% }) %>
						</div>
					</div>
				</div>

				<!-- Related Products -->
				<section class="related-products" aria-labelledby="related-heading">
					<h2 class="section-title" id="related-heading">You Might Also Like</h2>
					<ul class="related-grid" role="list">
						<% product.related.forEach(rel => { %>
						<li class="product-card">
							<img src="<%= rel.image %>" alt="" class="product-bg" />
							<div class="product-card__top">
								<span class="product-badge"><%= rel.badge || rel.category %></span>
								<span class="product-category"><%= rel.category %></span>
							</div>
							<h4><%= rel.name %></h4>
							<p><%= rel.desc %></p>
							<div class="product-card__bottom">
								<span class="price">$<%= rel.price.toLocaleString() %></span>
								<a href="/products/<%= rel.slug %>" class="product-link">View →</a>
							</div>
						</li>
						<% }) %>
					</ul>
				</section>

			</div>
		</main>

		<%- include('../partials/footer') %>
	</body>
</html>
